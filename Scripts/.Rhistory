## ssGSEA: single-sample enrichment score per cell line
run.ssGSEA2 <- function(exp_mat, gene_list, norm = FALSE) {
gsvaPar <- GSVA::ssgseaParam(exp_mat, gene_list, normalize = norm)
as.data.frame(t(GSVA::gsva(gsvaPar)))
}
WNT_scores <- run.ssGSEA2(
exp_mat   = as.matrix(counts_trim),
gene_list = list(EMT = wp_wnt_pluri)
)
WNT_scores <- run.ssGSEA2(
exp_mat   = as.matrix(counts_trim),
gene_list = list(WNT = wp_wnt_pluri)
)
cat("WNT scores computed via ssGSEA")
write.table(
x = WNT_scores,
file = paste0(path.mel, "CCLE_Exhaustion_WP_WNT_Pluri_", score_method, ".txt"),
sep = "\t",
quote = F,
row.names =
)
